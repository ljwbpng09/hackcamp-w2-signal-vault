# ─── Polymarket ──────────────────────────────────────────────────────────────
# CLOB token ID for the market you want to monitor.
# Find it at https://polymarket.com — open a market → "Prices" tab → copy token_id from URL
POLYMARKET_TOKEN_ID=22587775301869146748237913050505932485648958481571808324285560650057390882036

# Human-readable question shown on the dashboard
MARKET_QUESTION=Will Mexico win the 2026 FIFA World Cup?

# Optional HTTP/HTTPS proxy (axios auto-detects HTTPS_PROXY)
# HTTPS_PROXY=http://127.0.0.1:7890

# ─── LLM (OpenAI-compatible, default: DeepSeek) ──────────────────────────────
LLM_API_KEY=sk-cp-x7E1tyY4t2ZPPkp7fpe_gSfzReeteFdQOV27OA1neJ6IIG18lAzu040-gOmSnWiL85TEc8iSJ6hnZSDnldJRk7FVXtZhIaQ55YZeG2hgjllgSJXsHcIrvKk
LLM_BASE_URL=https://api.minimaxi.com/anthropic
LLM_MODEL=minimax-chat

# ─── Blockchain / viem (Sepolia testnet only — D2) ───────────────────────────
RPC_URL=https://sepolia.infura.io/v3/YOUR_PROJECT_ID
# NEVER commit the real key. Keep it local only.
WALLET_PRIVATE_KEY=0x...
CONTRACT_ADDRESS=0x...

# ─── Telegram (D4) ───────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=...
TELEGRAM_CHAT_ID=...

# ─── Output ──────────────────────────────────────────────────────────────────
# Path resolved relative to worker/ (cwd when you run npm run dev)
SNAPSHOT_OUTPUT_PATH=../web/public/snapshot.json
