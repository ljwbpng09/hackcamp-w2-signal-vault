# ─── Polymarket — Multi-market config ────────────────────────────────────────
#
# POLYMARKET_MARKETS: JSON array of markets to monitor simultaneously.
# Each entry needs a CLOB tokenId (YES outcome) and a human-readable question.
#
# To find a tokenId:
#   curl "https://clob.polymarket.com/markets/<conditionId>" | jq '.tokens[].token_id'
#
POLYMARKET_MARKETS=[{"tokenId":"108233603819467706476318984012158651931658302669301887462181073562758483842092","question":"Will France win the 2026 FIFA World Cup?"},{"tokenId":"18812649149814341758733697580460697418474693998558159483117100240528657629879","question":"Will Argentina win the 2026 FIFA World Cup?"},{"tokenId":"22587775301869146748237913050505932485648958481571808324285560650057390882036","question":"Will Mexico win the 2026 FIFA World Cup?"}]

# Legacy single-market fallback (used if POLYMARKET_MARKETS is not set)
# POLYMARKET_TOKEN_ID=<token id>
# MARKET_QUESTION=Will X win the 2026 FIFA World Cup?

# Optional HTTP/HTTPS proxy (axios auto-detects HTTPS_PROXY)
# HTTPS_PROXY=http://127.0.0.1:7890

# ─── LLM (OpenAI-compatible) ──────────────────────────────────────────────────
LLM_API_KEY=your-api-key
LLM_BASE_URL=https://api.minimaxi.com/v1
LLM_MODEL=MiniMax-Text-01

# ─── Blockchain / viem (Sepolia testnet only) ─────────────────────────────────
# Public fallback: https://ethereum-sepolia-rpc.publicnode.com (rate-limited)
# Better: get a free Infura/Alchemy key
SEPOLIA_RPC=https://ethereum-sepolia-rpc.publicnode.com
# NEVER commit the real key. Keep it local only.
WALLET_PRIVATE_KEY=0x...
CONTRACT_ADDRESS=0x...

# ─── Telegram ─────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=...
TELEGRAM_CHAT_ID=...

# ─── Output ───────────────────────────────────────────────────────────────────
# Path resolved relative to worker/ (cwd when you run npm run dev)
SNAPSHOT_OUTPUT_PATH=../web/public/snapshot.json
